@echo off
chcp 1251 >nul
title Установка локатора
color 0A

echo ========================================
echo    Установка панели управления сайтами
echo ========================================
echo.

:: Проверяем, запущен ли от имени администратора
net session >nul 2>&1
if %errorLevel% neq 0 (
    echo [!] ВНИМАНИЕ: Рекомендуется запускать от имени администратора!
    echo.
)

:: Устанавливаем пути
set XAMPP_HTDOCS=C:\xampp\htdocs
set LOCATOR_FILE=%XAMPP_HTDOCS%\locator\index_for_locator.php
set INDEX_FILE=%XAMPP_HTDOCS%\index.php
set BACKUP_FILE=%XAMPP_HTDOCS%\index_before_locator.php

echo [1/3] Проверка наличия папки XAMPP...
if not exist "%XAMPP_HTDOCS%" (
    echo [?] ОШИБКА: Папка XAMPP не найдена по пути: %XAMPP_HTDOCS%
    echo     Убедитесь, что XAMPP установлен в C:\xampp
    goto :error
)
echo [?] Папка XAMPP найдена

echo.
echo [2/3] Проверка наличия файла локатора...
if not exist "%LOCATOR_FILE%" (
    echo [?] ОШИБКА: Файл локатора не найден!
    echo     Ожидался файл: %LOCATOR_FILE%
    echo.
    echo     Убедитесь, что:
    echo     - Папка locator существует в C:\xampp\htdocs\
    echo     - В папке locator есть файл index_for_locator.php
    goto :error
)
echo [?] Файл локатора найден

echo.
echo [3/3] Выполнение операций...

:: Проверяем наличие существующего index.php
set BACKUP_CREATED=0
if exist "%INDEX_FILE%" (
    echo     - Найден существующий index.php, создаем резервную копию...
    
    :: Если резервная копия уже существует, удаляем её
    if exist "%BACKUP_FILE%" (
        del "%BACKUP_FILE%" >nul 2>&1
    )
    
    :: Переименовываем
    ren "%INDEX_FILE%" "index_before_locator.php"
    if %errorLevel% equ 0 (
        echo     [?] Резервная копия создана: index_before_locator.php
        set BACKUP_CREATED=1
    ) else (
        echo     [?] Ошибка при создании резервной копии
        goto :error
    )
) else (
    echo     - Существующий index.php не найден, резервная копия не требуется
)

:: Копируем новый index.php
echo     - Копирование нового index.php из locator\index_for_locator.php...
copy "%LOCATOR_FILE%" "%INDEX_FILE%" >nul
if %errorLevel% equ 0 (
    echo     [?] Файл успешно скопирован
) else (
    echo     [?] Ошибка при копировании файла
    goto :error
)

:: Проверяем результат
if exist "%INDEX_FILE%" (
    echo.
    echo ========================================
    echo    [?] УСТАНОВКА ЗАВЕРШЕНА УСПЕШНО!
    echo ========================================
    echo.
    echo   Что было сделано:
    if %BACKUP_CREATED%==1 (
    echo   - Создана резервная копия: index_before_locator.php
    ) else (
    echo   - Резервная копия не требовалась (index.php отсутствовал)
    )
    echo   - Установлен новый index.php из файла index_for_locator.php
    echo.
    echo   Теперь при переходе на http://localhost/
    echo   будет открываться ваша панель управления
    echo.
    echo   Если нужно вернуть всё обратно:
    echo   - Переименуйте index_before_locator.php обратно в index.php
    echo   - Или запустите файл uninstall_locator.bat
    echo.
    echo ========================================
    
    :: Спрашиваем, открыть ли браузер
    set /p OPEN_BROWSER="Открыть http://localhost/ в браузере? (Y/N): "
    if /i "%OPEN_BROWSER%"=="Y" (
        start http://localhost/
    ) else if /i "%OPEN_BROWSER%"=="Н" (
        echo   Браузер не открыт
    ) else if /i "%OPEN_BROWSER%"=="N" (
        echo   Браузер не открыт
    ) else (
        echo   Браузер не открыт
    )
    
    goto :end
) else (
    :error
    color 0C
    echo.
    echo ========================================
    echo    [?] ОШИБКА ПРИ УСТАНОВКЕ!
    echo ========================================
    echo.
    echo   Проверьте:
    echo   1. Запущен ли XAMPP (не обязательно, но желательно)
    echo   2. Существует ли папка C:\xampp\htdocs\locator\
    echo   3. Есть ли файл index_for_locator.php в папке locator
    echo   4. Достаточно ли прав на запись в C:\xampp\htdocs\
    echo.
    echo   Если ошибка повторяется, запустите файл
    echo   от имени администратора (правый клик -> Запуск от имени администратора)
    echo.
    echo ========================================
)

:end
echo.
pause